<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Horizontal ScrollView containing the status items -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="horizontal"
        android:layout_marginTop="8dp"
        android:background="#FFFFFF">

        <!-- LinearLayout to arrange items horizontally -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <!-- Each item, in this case TextViews for each status -->
            <TextView
                android:id="@+id/awaiting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Awaiting"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:padding="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/button_background"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/assigned"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assigned"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:padding="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/button_background"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/reAssigned"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Re-Assigned"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:padding="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/button_background"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/raised"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Raised"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:padding="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/button_background"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/declined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Declined"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:padding="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/button_background"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Your TextView for the Task fragment's data -->
    <TextView
        android:id="@+id/textTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Placeholder Text"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        android:textSize="16sp" />

    <!-- Title bar or other top UI elements can go here -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This is Task Fragment"
        android:textSize="24sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:padding="8dp" />
</LinearLayout>
