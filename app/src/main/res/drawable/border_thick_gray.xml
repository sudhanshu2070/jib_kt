<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Set the background color to transparent so we only see the border -->
    <solid android:color="@android:color/transparent" />

    <!-- Define the border thickness -->
    <stroke
        android:color="#808080"
        android:width="4dp" />     <!-- Border Thickness -->

    <!-- Set the corner radius for rounded edges (optional) -->
<!--    <corners android:radius="0dp" />-->

    <padding
        android:bottom="5dp"
        android:top="5dp"></padding>
<!--    <padding android:left="0dp" android:right="0dp" android:top="0dp" android:bottom="0dp" />-->
</shape>